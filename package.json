{
	"name": "monorepo",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "concurrently --kill-others --raw \"npm run dev --prefix apps/web\"",
		"build": "concurrently --raw \"npm run build --prefix apps/web\"",
		"start": "node server/index.js",
		"lint": "concurrently --raw \"npm run lint --prefix apps/web\""
	},
	"devDependencies": {
		"concurrently": "^9.1.2"
	},
	"workspaces": [
		"apps/*"
	],
	"dependencies": {
		"mysql2": "^3.22.1",
		"run": "^1.5.0"
	}
}
