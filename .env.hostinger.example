# Nornsight - Hostinger preprod
# Copie ce contenu dans les variables d'environnement Hostinger

OPENAI_API_KEY=replace_with_your_openai_api_key
OPENAI_MODEL=gpt-5.4-mini
OPENAI_FREE_MODEL=gpt-4.1-mini
OPENAI_FULL_MODEL=gpt-5.4-mini
APP_BASE_URL=https://nornsight.example.com

# Email admin non limite pour les tests
ADMIN_EMAILS=kevin.legros@yahoo.fr,test@test.fr

# Base MySQL Hostinger
# Tu peux laisser ces variables vides pour une premiere preprod
# si tu veux rester temporairement sur le fallback local.
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=replace_with_mysql_user
MYSQL_PASSWORD=replace_with_mysql_password
MYSQL_DATABASE=replace_with_mysql_database

# Stripe
STRIPE_SECRET_KEY=replace_with_stripe_secret_key
STRIPE_WEBHOOK_SECRET=replace_with_stripe_webhook_secret
STRIPE_PRICE_CENTS=590
STRIPE_CURRENCY=eur

# SMTP transactionnel
SMTP_HOST=replace_with_smtp_host
SMTP_PORT=587
SMTP_USER=replace_with_smtp_user
SMTP_PASSWORD=replace_with_smtp_password
SMTP_SECURE=false
MAIL_FROM_EMAIL=contact@example.com
MAIL_FROM_NAME=Nornsight
MAIL_REPLY_TO=contact@example.com

# Cloudflare / proxy
API_PUBLIC_HOSTNAME=nornsight.example.com
CLOUDFLARE_ZONE=example.com
TRUST_PROXY_HEADERS=true

# Port Node.js
# Hostinger peut l'injecter automatiquement, mais on garde une valeur par defaut
PORT=3000
